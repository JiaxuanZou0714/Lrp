# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Required: HuggingFace Token for dataset access
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Required: WandB API Key for experiment tracking
# Get from: https://wandb.ai/settings
WANDB_API_KEY=wandb_your_api_key_here

# Optional: WandB Project Name (default: llama-pretraining)
WANDB_PROJECT=Lrp

# Optional: WandB Entity/Team Name
# WANDB_ENTITY=your_wandb_entity_here
